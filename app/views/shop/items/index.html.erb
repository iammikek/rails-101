<% content_for :title, "Items" %>

<div class="page-header">
  <div>
    <h1>Items</h1>
    <p class="muted"><%= @total_count %> total · page <%= @page %> of <%= @total_pages %></p>
  </div>
  <% if current_shop_user %>
    <a class="button" href="<%= shop_new_item_path %>">Add item</a>
  <% end %>
</div>

<form method="get" class="filter-form panel">
  <h2>Filter</h2>
  <div class="field-grid">
    <div class="mb-3">
      <label for="name_contains">Name contains</label>
      <input type="text" id="name_contains" name="name_contains" value="<%= @filters["name_contains"] %>">
    </div>
    <div class="mb-3">
      <label for="category_id">Category</label>
      <select id="category_id" name="category_id">
        <option value="">Any</option>
        <% @categories.each do |category| %>
          <option value="<%= category.id %>" <%= "selected" if @filters["category_id"].to_s == category.id.to_s %>><%= category.name %></option>
        <% end %>
      </select>
    </div>
    <div class="mb-3">
      <label for="min_price">Min price</label>
      <input type="number" step="0.01" id="min_price" name="min_price" value="<%= @filters["min_price"] %>">
    </div>
    <div class="mb-3">
      <label for="max_price">Max price</label>
      <input type="number" step="0.01" id="max_price" name="max_price" value="<%= @filters["max_price"] %>">
    </div>
  </div>
  <div class="actions">
    <button type="submit" class="button">Apply</button>
    <a class="button secondary" href="<%= shop_items_path %>">Clear</a>
  </div>
</form>

<section class="panel">
  <% if @items.any? %>
    <table>
      <thead>
        <tr>
          <th>Name</th>
          <th>Category</th>
          <th>Price</th>
        </tr>
      </thead>
      <tbody>
        <% @items.each do |item| %>
          <tr>
            <td><a href="<%= shop_item_path(item) %>"><%= item.name %></a></td>
            <td><%= item.category&.name || "—" %></td>
            <td>$<%= item.price %></td>
          </tr>
        <% end %>
      </tbody>
    </table>

    <% if @total_pages > 1 %>
      <nav class="pagination">
        <% if @page > 1 %>
          <a href="<%= shop_items_path(@filters.merge("page" => @page - 1)) %>">← Previous</a>
        <% end %>
        <% if @page < @total_pages %>
          <a href="<%= shop_items_path(@filters.merge("page" => @page + 1)) %>">Next →</a>
        <% end %>
      </nav>
    <% end %>
  <% else %>
    <p>No items match your filters.</p>
  <% end %>
</section>
