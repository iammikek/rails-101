<% content_for :title, "Home" %>

<section class="hero">
  <p class="eyebrow">Full-stack Rails</p>
  <h1>Catalog Shop</h1>
  <p class="lead">
    This page is rendered by ERB on the server — not JSON from the API.
    The same <code>ItemService</code> powers both this UI and <a href="/items">/items</a>.
  </p>
  <div class="actions">
    <a class="button" href="<%= shop_items_path %>">Browse items</a>
    <% if current_shop_user %>
      <a class="button secondary" href="<%= shop_new_item_path %>">Add item</a>
    <% else %>
      <a class="button secondary" href="<%= shop_login_path %>">Log in to add items</a>
    <% end %>
  </div>
</section>

<section class="panel">
  <h2>Catalog stats</h2>
  <% if @stats[:total_items].zero? %>
    <p>No items yet. Create one via the API or log in and use <a href="<%= shop_new_item_path %>">Add item</a>.</p>
  <% else %>
    <dl class="stats-grid">
      <div><dt>Total items</dt><dd><%= @stats[:total_items] %></dd></div>
      <div><dt>Average price</dt><dd>$<%= @stats[:average_price] %></dd></div>
      <div><dt>Price range</dt><dd>$<%= @stats[:min_price] %> – $<%= @stats[:max_price] %></dd></div>
      <div><dt>Uncategorized</dt><dd><%= @stats[:uncategorized_count] %></dd></div>
    </dl>

    <% if @stats[:by_category].any? %>
      <h3>By category</h3>
      <table>
        <thead>
          <tr>
            <th>Category</th>
            <th>Items</th>
            <th>Avg price</th>
          </tr>
        </thead>
        <tbody>
          <% @stats[:by_category].each do |row| %>
            <tr>
              <td><%= row[:category_name] %></td>
              <td><%= row[:item_count] %></td>
              <td>$<%= row[:average_price] %></td>
            </tr>
          <% end %>
        </tbody>
      </table>
    <% end %>
  <% end %>
</section>

<section class="panel muted-panel">
  <h2>API vs browser UI</h2>
  <table class="compare">
    <thead>
      <tr>
        <th></th>
        <th>JSON API</th>
        <th>Shop (ERB)</th>
      </tr>
    </thead>
    <tbody>
      <tr>
        <td>Response</td>
        <td><code>application/json</code></td>
        <td><code>text/html</code></td>
      </tr>
      <tr>
        <td>Auth</td>
        <td>JWT Bearer token</td>
        <td>Session cookie</td>
      </tr>
      <tr>
        <td>Client</td>
        <td>curl, mobile app, SPA</td>
        <td>Browser (full page loads)</td>
      </tr>
    </tbody>
  </table>
</section>
