<% content_for :title, "Create account" %>

<section class="panel narrow">
  <h1>Create account</h1>
  <p class="muted">
    Sign up here for the shop. The JSON API still has its own
    <code>POST /auth/register</code> endpoint for mobile apps and curl.
  </p>

  <%= form_with url: shop_register_path, method: :post, local: true do %>
    <div class="mb-3">
      <label for="email">Email</label>
      <input type="email" id="email" name="email" value="<%= params[:email] %>" required>
    </div>
    <div class="mb-3">
      <label for="password">Password</label>
      <input type="password" id="password" name="password" required>
    </div>
    <div class="mb-3">
      <label for="password_confirmation">Confirm password</label>
      <input type="password" id="password_confirmation" name="password_confirmation" required>
    </div>
    <div class="actions">
      <button type="submit" class="button">Create account</button>
    </div>
  <% end %>

  <p class="muted">
    Already have an account?
    <a href="<%= shop_login_path %>">Log in</a>
  </p>
</section>
