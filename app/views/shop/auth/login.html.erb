<% content_for :title, "Log in" %>

<section class="panel narrow">
  <h1>Log in</h1>
  <p class="muted">
    Browser session auth — different from <code>POST /auth/login</code>, which returns a JWT for the API.
  </p>

  <%= form_with url: shop_login_path, method: :post, local: true do %>
    <div class="mb-3">
      <label for="email">Email</label>
      <input type="email" id="email" name="email" value="<%= params[:email] %>" required autofocus>
    </div>
    <div class="mb-3">
      <label for="password">Password</label>
      <input type="password" id="password" name="password" required>
    </div>
    <div class="actions">
      <button type="submit" class="button">Log in</button>
    </div>
  <% end %>

  <p class="muted">
    No account?
    <a href="<%= shop_register_path %>">Create account</a>
  </p>
</section>
