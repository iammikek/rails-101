# Local SQLite is the default (no DATABASE_URL needed).
# Docker Compose sets PostgreSQL via DATABASE_URL.

# SECRET_KEY_BASE is auto-generated for development.
# For Docker/production, set an explicit value:
# SECRET_KEY_BASE=change-me-to-a-long-random-string

# JWT signing secret (defaults to SECRET_KEY_BASE if unset)
# JWT_SECRET=change-me-jwt-secret

# Bind port for `rails server` / Makefile (default 8012)
# PORT=8012
